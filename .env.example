# WhatsApp / Meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# AI — Gemini 2.5 Flash (recommended) or Groq (fallback)
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_STT_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Voice replies (ElevenLabs TTS — reply with voice when customer sends voice note)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Central database (Railway Postgres — use DATABASE_URL or DATABASE_URL_CENTRAL)
DATABASE_URL_CENTRAL=
# Tenant database (kfc-web / kababjees-web services only)
TENANT_DATABASE_URL=
# External tenant DB URLs for agent service (register in central registry)
DATABASE_URL_KFC=
DATABASE_URL_KABABJEES=
# Redis (Railway Redis plugin)
REDIS_URL=

# Service topology: agent | admin | kfc | kababjees | all
SERVICE_MODE=all

# Auth & encryption
JWT_SECRET=
JWT_ALG=HS256
FERNET_KEY=

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Tenant DB provisioning (same Postgres cluster as central)
TENANT_DB_HOST=
TENANT_DB_PORT=5432
TENANT_DB_ADMIN_URL=

# Optional
PHONE_HASH_PEPPER=
ENVIRONMENT=development
