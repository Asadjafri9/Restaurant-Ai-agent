# Meta WhatsApp webhook - use these EXACT values in Meta Developer Console
# Callback URL (ngrok local testing):
WHATSAPP_CALLBACK_URL=https://tribesman-ground-sludge.ngrok-free.dev/webhook
# Callback URL (Railway production):
# WHATSAPP_CALLBACK_URL=https://restaurant-watsapp-ai-automation-production.up.railway.app/webhook

# Verify token - must match Meta "Verify token" field AND server env WHATSAPP_VERIFY_TOKEN
WHATSAPP_VERIFY_TOKEN=restaurant_whatsapp_verify_2024

# From Meta -> WhatsApp -> API Setup -> Phone number ID
WHATSAPP_PHONE_NUMBER_ID=

# Paste your access token (already set on Railway)
WHATSAPP_ACCESS_TOKEN=

# From Meta App Dashboard -> App Settings -> Basic -> App Secret
WHATSAPP_APP_SECRET=
